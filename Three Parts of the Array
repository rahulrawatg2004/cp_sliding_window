import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        long arr[] = new long[n];
        for(int i=0;i<n;i++){
            arr[i] = sc.nextLong();
        }
        if(n==0){
            System.out.println(0);
            return;
        }
        int left = 0;
        int right = n-1;
        long leftSum = arr[left];
        long rightSum = arr[right];
        long max = 0;
        while(left<right){
            if(leftSum==rightSum){
                max = Math.max(max,leftSum);
                left++;
                leftSum += arr[left];
                right--;
                rightSum += arr[right];
            }
            if(leftSum>rightSum){
                right--;
                rightSum += arr[right];
            }
            if(rightSum>leftSum){
                left++;
                leftSum += arr[left];
            }
        }
        System.out.println(max);
    }
}
