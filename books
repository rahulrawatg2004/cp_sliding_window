import java.util.*;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int t = sc.nextInt();
        int arr[] = new int[n];
        for(int i=0;i<n;i++){
            arr[i] = sc.nextInt();
        }
        int left = 0;
        int maxsize = 0;
        int time = 0;
        for(int right=0;right<n;right++){
            time += arr[right];
            while(time>t){
                time -= arr[left];
                left++;
                
            }
            maxsize = Math.max(maxsize,right-left+1);
        }
        System.out.println(maxsize);
    }
}
